# Copiá este archivo a .env.local y completá con tus llaves reales.
# .env.local NUNCA se sube a GitHub (agregalo a .gitignore).

# --- Supabase (Fase 1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Fase 2) - en modo test al principio ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Calendar (Fase 3) - service account ---
# Crear service account en Google Cloud, habilitar Calendar API y compartir el
# calendario de Sage con este email. La private key va entre comillas y con los
# saltos de linea como \n literales. Ver docs/PHASE3-GOOGLE.md.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# --- Resend (Fase 4) ---
RESEND_API_KEY=
SAGE_NOTIFY_EMAIL=hello@thesageessence.com
