# Copiá este archivo a .env.local y completá con tus llaves reales.
# .env.local NUNCA se sube a GitHub (agregalo a .gitignore).

# --- Supabase (Fase 1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Fase 2) - en modo test al principio ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Calendar (Fase 3) - OAuth ---
# Crear un OAuth client (Web) en Google Cloud, configurar el consent screen y
# autorizar una vez en /api/google/oauth/start para obtener el refresh token.
# Ver docs/PHASE3-GOOGLE.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# --- Resend (Fase 4) ---
# Sin RESEND_API_KEY los emails caen a modo log (se imprimen, no se envian).
RESEND_API_KEY=
SAGE_FROM_EMAIL=hello@thesageessence.com
SAGE_NOTIFY_EMAIL=hello@thesageessence.com
SAGE_REVIEW_URL=

# --- Cron (Fase 4) ---
# Vercel manda este secreto como Authorization: Bearer en los cron jobs.
CRON_SECRET=

# --- Panel admin (Fase 6) ---
# Contrasena para entrar al panel en /login. ADMIN_SESSION_SECRET firma la
# cookie de sesion (poner una cadena larga al azar).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
